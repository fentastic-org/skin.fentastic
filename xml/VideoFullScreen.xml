<?xml version="1.0" encoding="utf-8"?>
<window>
	<defaultcontrol></defaultcontrol>
	<onload condition="Skin.HasSetting(Enable.PlaybackInfoOverlay)">Skin.TimerStart(playbackinfo_overlay)</onload>
	<controls>
		<control type="group" id="0">
			<control type="label" id="10">
				<left>45</left>
				<top>15</top>
				<width>1770</width>
				<height>100</height>
				<label></label>
				<font>font12</font>
				<shadowcolor>black</shadowcolor>
			</control>
			<control type="label" id="11">
				<left>45</left>
				<top>45</top>
				<width>1770</width>
				<height>100</height>
				<label></label>
				<font>font12</font>
				<shadowcolor>black</shadowcolor>
			</control>
			<control type="label" id="12">
				<left>45</left>
				<top>75</top>
				<width>1770</width>
				<height>100</height>
				<label></label>
				<font>font12</font>
				<shadowcolor>black</shadowcolor>
			</control>
		</control>
		<control type="group" id="1">
			<depth>DepthOSD+</depth>
			<visible>Player.Caching + Integer.IsGreater(Player.CacheLevel,0)</visible>
			<animation effect="fade" delay="300" time="200">Visible</animation>
			<animation effect="fade" delay="200" time="150">Hidden</animation>
			<centerleft>50%</centerleft>
			<width>110</width>
			<centertop>50%</centertop>
			<height>110</height>
			<control type="image" id="1">
				<centerleft>50%</centerleft>
				<centertop>50%</centertop>
				<width>110</width>
				<height>110</height>
				<texture colordiffuse="BFFFFFFF">osd/buffer-bg.png</texture>
			</control>
			<control type="image" id="1">
				<centerleft>50%</centerleft>
				<centertop>50%</centertop>
				<width>92</width>
				<height>92</height>
				<texture>dialogs/extendedprogress/loading-back.png</texture>
			</control>
			<control type="image" id="1">
				<centerleft>50%</centerleft>
				<centertop>50%</centertop>
				<width>92</width>
				<height>92</height>
				<texture colordiffuse="button_focus">$INFO[Player.CacheLevel,dialogs/volume/progress/p,.png]</texture>
			</control>
			<control type="label" id="1">
				<description>buffering value</description>
				<label>$INFO[Player.CacheLevel]</label>
				<centerleft>50%</centerleft>
				<centertop>50%</centertop>
				<width>200</width>
				<height>200</height>
				<aligny>center</aligny>
				<align>center</align>
				<font>font13</font>
			</control>
		</control>
		<!-- Playback Info Overlay - shows briefly at start of playback -->
		<control type="group">
			<visible>Skin.HasSetting(Enable.PlaybackInfoOverlay) + Skin.TimerIsRunning(playbackinfo_overlay)</visible>
			<visible>!Window.IsActive(videoosd) + !Window.IsActive(seekbar) + !Window.IsActive(playerprocessinfo)</visible>
			<visible>!VideoPlayer.Content(LiveTV)</visible>
			<animation effect="fade" start="0" end="100" time="500">Visible</animation>
			<animation effect="fade" start="100" end="0" time="800">Hidden</animation>
			<depth>DepthOSD</depth>
			<!-- Background gradient -->
			<control type="image">
				<left>0</left>
				<top>0</top>
				<width>100%</width>
				<height>220</height>
				<texture>frame/osdfade.png</texture>
			</control>
			<!-- Title and Year -->
			<control type="label">
				<left>30</left>
				<top>25</top>
				<width>1400</width>
				<height>50</height>
				<font>font45_title</font>
				<shadowcolor>black</shadowcolor>
				<label>$VAR[PlaybackInfoTitleVar]</label>
			</control>
			<!-- Subtitle (episode info or genre) -->
			<control type="label">
				<left>30</left>
				<top>80</top>
				<width>1400</width>
				<height>35</height>
				<font>font13</font>
				<shadowcolor>black</shadowcolor>
				<label>$VAR[PlaybackInfoSubVar]</label>
			</control>
			<!-- Media flags row: MPAA + codecs -->
			<control type="grouplist">
				<left>30</left>
				<top>125</top>
				<width>1200</width>
				<height>60</height>
				<orientation>horizontal</orientation>
				<itemgap>5</itemgap>
				<!-- MPAA Rating badge -->
				<control type="group">
					<visible>!String.IsEmpty(VideoPlayer.mpaa)</visible>
					<width>140</width>
					<control type="label">
						<width>140</width>
						<height>60</height>
						<align>center</align>
						<aligny>center</aligny>
						<label>$INFO[VideoPlayer.mpaa]</label>
						<font>font_flag</font>
					</control>
					<include content="MediaFlag">
						<param name="texture" value="flags/flag.png" />
					</include>
				</control>
				<!-- Video Codec -->
				<include content="MediaFlag">
					<param name="texture" value="$INFO[VideoPlayer.VideoCodec,flags/videocodec/,.png]" />
				</include>
				<!-- Video Resolution -->
				<include content="MediaFlag">
					<param name="texture" value="$INFO[VideoPlayer.VideoResolution,flags/videoresolution/,.png]" />
				</include>
				<!-- HDR Type -->
				<include content="MediaFlag">
					<param name="texture" value="$INFO[VideoPlayer.HdrType,flags/videohdr/,.png]" />
					<param name="visible" value="!String.IsEmpty(VideoPlayer.HdrType)" />
				</include>
				<!-- Aspect Ratio -->
				<include content="MediaFlag">
					<param name="texture" value="$INFO[VideoPlayer.VideoAspect,flags/aspectratio/,.png]" />
				</include>
				<!-- Audio Codec -->
				<include content="MediaFlag">
					<param name="texture" value="$INFO[VideoPlayer.AudioCodec,flags/audiocodec/,.png]" />
				</include>
				<!-- Audio Channels -->
				<include content="MediaFlag">
					<param name="texture" value="$INFO[VideoPlayer.AudioChannels,flags/audiochannel/,.png]" />
				</include>
			</control>
		</control>
	</controls>
</window>
